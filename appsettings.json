{
    "Adapter": {
        "Port": 8787,
        "MaxReconnectAttempts": 10
    },
    "Sap": {
        "WaitTimeoutMs": 20000,
        "MaxCellReads": 500,
        "MaxNodes": 5000,
        "MaxSnapshotDurationMs": 4000,
        "Provider": "real"
    },
    "Recorder": {
        "Enabled": true,
        "OutputDir": "artifacts/replays"
    },
    "Idempotency": {
        "MaxEntries": 500,
        "TtlSeconds": 300
    },
    "Serilog": {
        "MinimumLevel": "Information",
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/adapter-.log",
                    "rollingInterval": "Day",
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
                }
            }
        ]
    }
}